# ===========================================
# ERP Fenix Soft - Plantilla de Variables de Entorno
# ===========================================
# Uso: Copia este archivo a .env.local o .env.production y completa los valores
# -------------------------------------------
# IMPORTANTE: Este archivo SÍ puede estar en Git (no tiene secrets reales)
# -------------------------------------------

# -------------------------------------------
# Django Core
# -------------------------------------------
SECRET_KEY=cambia-esta-clave-por-una-segura
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# -------------------------------------------
# Base de Datos
# -------------------------------------------
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=

# -------------------------------------------
# Email
# -------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=

# -------------------------------------------
# Allauth / Authentication
# -------------------------------------------
ACCOUNT_EMAIL_VERIFICATION=optional

# -------------------------------------------
# Site Framework
# -------------------------------------------
SITE_ID=1
SITE_NAME=ERP Fenix Soft
SITE_DOMAIN=http://localhost:8000

# -------------------------------------------
# CSRF & Session
# -------------------------------------------
CSRF_TRUSTED_ORIGINS=http://localhost:8000
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
